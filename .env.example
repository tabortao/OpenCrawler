# Server Configuration
HOST=127.0.0.1
PORT=8000

# Output Configuration
OUTPUT_DIR=output

# Anti-Bot Configuration
PROXY_URL=

# Platform Cookies (Required for Zhihu, Xiaohongshu)
# Format: name1=value1; name2=value2; name3=value3
ZHIHU_COOKIE=
XHS_COOKIE=

# API Authentication Token
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 如果不设置，则 API 不需要认证（不推荐在生产环境中使用）
# 安全提示：
# 1. 请使用高强度随机字符串（至少 32 字节）
# 2. 定期轮换令牌
# 3. 不要将令牌提交到代码仓库
# 4. 不要在日志或错误信息中显示令牌
API_TOKEN=
